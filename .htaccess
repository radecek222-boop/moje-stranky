# ======================================
# WGS Service - Apache Configuration
# ======================================

# Enable Rewrite Engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ======================================
    # WHITE LABEL subdoména: wl.wgs-service.cz → white-label.php
    # Všechny requesty na wl subdoménu jdou na landing page
    # Výjimky: assets, api (formulář), .well-known
    # ======================================
    RewriteCond %{HTTP_HOST} ^wl\.wgs-service\.cz$ [NC]
    RewriteCond %{REQUEST_URI} !^/assets/
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteCond %{REQUEST_URI} !^/\.well-known/
    RewriteCond %{REQUEST_URI} !^/white-label(\.php)?$
    RewriteRule ^(.*)$ /white-label.php [L]

    # ======================================
    # SECURITY: Blokovat přístup k citlivým adresářům
    # ======================================
    RewriteRule ^(logs|config|backups|migrations|setup|scripts|temp|docs)(/|$) - [F,L]

    # ======================================
    # CRITICAL: Static assets - NO REWRITE (must be FIRST!)
    # ======================================
    RewriteRule ^assets/ - [L]
    RewriteRule ^uploads/ - [L]
    RewriteRule ^tools/ - [L]

    # ======================================
    # Přesměrování debug/diagnostika nástrojů do /tools/
    # (staré záložky → nová umístění)
    # ======================================
    # Přesměrování zrušené stránky nasesluzby na domovskou
    RewriteRule ^nasesluzby(\.php)?$ / [R=301,L]
    RewriteRule ^nasesluzby$ / [R=301,L]

    # Přesměrování staré URL aktuality → nasetipy (SEO 301)
    RewriteRule ^aktuality(\.php)?$ /nasetipy [R=301,L]

    # Přesměrování staré URL novareklamace → objednatservis (SEO 301)
    RewriteRule ^novareklamace(\.php)?$ /objednatservis [R=301,L]

    RewriteRule ^(debug_[^/]+\.php)$ /tools/$1 [R=301,L]
    RewriteRule ^(diagnostika_[^/]+\.php)$ /tools/$1 [R=301,L]
    RewriteRule ^(check_[^/]+\.php)$ /tools/$1 [R=301,L]
    RewriteRule ^(test_[^/]+\.php)$ /tools/$1 [R=301,L]
    RewriteRule ^(analyza_[^/]+\.php)$ /tools/$1 [R=301,L]
    RewriteRule ^(audit_[^/]+\.php)$ /tools/$1 [R=301,L]

    # ======================================
    # CRITICAL: Let's Encrypt - MUST be BEFORE Force HTTPS!
    # Allows HTTP challenge for certificate renewal
    # ======================================
    RewriteRule ^\.well-known/ - [L]

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ======================================
    # CRITICAL: Exclude /app/ and /api/ from ALL rewrites
    # ======================================
    RewriteCond %{REQUEST_URI} ^/app/ [OR]
    RewriteCond %{REQUEST_URI} ^/api/
    RewriteRule ^ - [L]

    # ======================================
    # CENTRÁLNÍ ROUTER - parametrizované čisté URL
    # Musí být PŘED obecnými clean URL pravidly
    # ======================================

    # /r/{cislo}     → zkrácené linky na reklamace
    RewriteRule ^r(/.*)?$ router.php [L,QSA]

    # /qr/{cislo}    → QR code redirecty s logováním
    RewriteRule ^qr(/.*)?$ router.php [L,QSA]

    # /zdravi        → health check endpoint
    RewriteRule ^zdravi$ router.php [L,QSA]

    # /api/v2/*      → nová verze API přes router
    RewriteRule ^api/v2(/.*)?$ router.php [L,QSA]

    # ======================================
    # Clean URLs - Remove .php extension
    # ======================================

    # Redirect .php requests to extensionless URLs
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.php\ HTTP
    # Prevent redirect loops when a directory with the same name exists (e.g. admin.php ↔ /admin)
    RewriteCond %{DOCUMENT_ROOT}/%1 !-d
    # ✅ FIX: Exclude photocustomer.php from redirect (needs to maintain session)
    RewriteCond %{REQUEST_URI} !^/photocustomer\.php$ [NC]
    # ✅ FIX: Exclude sw.php - Service Workers CANNOT be redirected
    RewriteCond %{REQUEST_URI} !^/sw\.php$ [NC]
    # ✅ FIX: Exclude pwa-splash.php - PWA entry point CANNOT be redirected
    RewriteCond %{REQUEST_URI} !^/pwa-splash\.php$ [NC]
    RewriteRule ^(.+)\.php$ /$1 [R=301,L]

    # Serve .php files for extensionless URLs
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+)$ $1.php [L,QSA]

</IfModule>

# ======================================
# Security Headers
# ======================================

<IfModule mod_headers.c>
    # HTTP Strict Transport Security (HSTS)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Content Security Policy (CSP) je nastavena v includes/security_headers.php
    # POZOR: Duplicitni CSP hlavicky (Apache + PHP) by browser vynutil OBE - protoze
    # browser bere prunik, muze to zpusobit neocekavane blokovani (napr. Google Fonts).
    # CSP je proto pouze v PHP souboru security_headers.php - NE zde.
    # Header always set Content-Security-Policy "..." - ZAKAZANO

    # Cross-Origin Opener Policy (COOP)
    Header always set Cross-Origin-Opener-Policy "same-origin"

    # Cross-Origin Resource Policy (CORP)
    Header always set Cross-Origin-Resource-Policy "same-origin"

    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"

    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy
    # microphone=(self), camera=(self) - povoleno pro hlasové poznámky a fotky
    Header always set Permissions-Policy "geolocation=(), microphone=(self), camera=(self)"

    # Remove Server signature
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# ======================================
# Performance - Browser Caching
# ======================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType application/manifest+json "access plus 1 week"
    ExpiresByType application/json "access plus 1 year"
</IfModule>

# PERFORMANCE FIX: Explicitní Cache-Control pro statické assety
<IfModule mod_headers.c>
    # ======================================
    # PWA CRITICAL: Service Worker NESMÍ být cachován
    # ======================================
    <FilesMatch "^sw\.(js|php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
    </FilesMatch>

    # PWA Manifest - krátký cache (1 hodina) pro rychlejší aktualizace
    <FilesMatch "^manifest\.json$">
        Header set Cache-Control "public, max-age=3600"
    </FilesMatch>

    # CSS a JS soubory - cache na 1 rok (s version query string pro invalidaci)
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Obrázky - cache na 1 rok
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Fonty - cache na 1 rok
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Source maps - cache na 1 rok (pro debugování produkce)
    <FilesMatch "\.map$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ======================================
# Compression
# ======================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ======================================
# Directory Protection
# ======================================

Options -Indexes +FollowSymLinks

<FilesMatch "(^\.htaccess|^\.env|\.log|\.sql|\.md|composer\.(json|lock)|package(-lock)?\.json)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ======================================
# MIME Types
# ======================================

<IfModule mod_mime.c>
    AddType application/javascript js mjs
    AddType text/javascript js
    AddType image/webp webp
    AddType image/svg+xml svg svgz
    AddType font/woff woff
    AddType font/woff2 woff2
    AddType font/ttf ttf
    AddType font/otf otf
    AddType application/manifest+json webmanifest
</IfModule>

# ======================================
# PHP Session Settings - KRITICKÁ OPRAVA
# ======================================

<IfModule mod_php.c>
    # Session cookie parametry - VYNUCENO na úrovni Apache
    php_value session.cookie_lifetime 3600
    php_value session.gc_maxlifetime 3600
    php_flag session.cookie_httponly On
    php_flag session.cookie_secure On
    php_value session.cookie_samesite Lax
    php_flag session.use_only_cookies On
    php_value session.cookie_path /
</IfModule>

# Pro PHP-FPM (pokud mod_php není dostupný)
<IfModule !mod_php.c>
    # Session nastavení přes .user.ini nebo php-fpm config
    # Tyto hodnoty budou použity pokud mod_php není aktivní
</IfModule>
